{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["jest", "@testing-library/jest-dom", "node"],
    "allowJs": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false
  },
  "include": ["src", "__tests__"],
  "exclude": ["node_modules", "dist"]
}
